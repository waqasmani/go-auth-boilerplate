APP_ENV=development
APP_PORT=8080

DB_DSN=root:password@tcp(localhost:3306)/auth_db?parseTime=true&charset=utf8mb4&loc=UTC

# Single key — legacy path, works with no other changes
JWT_SECRET=<output of openssl rand -hex 64>

# Mid-rotation — both keys present, v2 signs new tokens, v1 still validates old ones
JWT_KEYS=[{"id":"v1","secret":"<key1>","active":false},{"id":"v2","secret":"<key2>","active":true}]
JWT_ISSUER=go-auth-boilerplate
JWT_AUDIENCE=go-auth-boilerplate-users
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

RATE_LIMIT_RATE=5.0
RATE_LIMIT_BURST=10
RATE_LIMIT_MAX_KEYS=10_000

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_HEADERS="Authorization,Content-Type,X-Request-ID"
CORS_ALLOW_CREDENTIALS=true
CORSMaxAge=43200 # 12 hours

FRONT_END_DOMAIN=http://localhost:8080

SEC_HSTS_ENABLED=true
SEC_HSTS_MAX_AGE=63_072_000 # 2 years

# CIDR block(s) of your load balancer / ingress layer.
# Example: 10.0.0.0/8 for an AWS internal NLB, 192.168.1.0/24 for a VPC ALB.
# Leave empty in development (direct connections, no proxy header trust).
TRUSTED_PROXY_CIDRS=10.0.0.0/8

# Leave HOST empty (or omit entirely) to disable email
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=false
EMAIL_FROM=App Name <noreply@example.com>

# Minimum 32 bytes required
OTP_HMAC_SECRET=kn4MYE5SO1aYmmPaT9Yig6tSqHdrjs9IdiQDOGT6Fb

# TOTP — generate with: openssl rand -base64 32
# Initial deployment (single key, legacy format still works):
TOTP_SECRET=<32-byte-base64>

# Rotation step 1 — add new key, old stays active:
TOTP_KEYS=[{"id":"v1","key":"<old-key>","active":true},{"id":"v2","key":"<new-key>","active":false}]

# Rotation step 2 — flip active, old key kept for decryption of existing secrets:
TOTP_KEYS=[{"id":"v1","key":"<old-key>","active":false},{"id":"v2","key":"<new-key>","active":true}]

# Rotation step 3 — after all secrets re-encrypted or users re-enrolled, remove old key:
TOTP_KEYS=[{"id":"v2","key":"<new-key>","active":true}]
TOTP_ISSUER=MyApp          # optional, defaults to "go-auth-boilerplate"
TOTP_PERIOD=30             # optional, RFC 6238 default
TOTP_DIGITS=6              # optional, 6 or 8

# Minimum 32 bytes required
OTP_HMAC_SECRET=kn4MYE5SO1aYmmPaT9Yig6tSqHdrjs9IdiQDOGT6Fb

# TOTP — generate with: openssl rand -base64 32
TOTP_SECRET=<32+ byte key, different from OTP_HMAC_SECRET>
TOTP_ISSUER=MyApp          # optional, defaults to "go-auth-boilerplate"
TOTP_PERIOD=30             # optional, RFC 6238 default
TOTP_DIGITS=6              # optional, 6 or 8
TOTP_REPLAY_CACHE_POLICY=local_fallback
# Cookie policy (cross-site SPA requires none + true)
COOKIE_SAMESITE=none          # lax | strict | none  (default: lax)
COOKIE_SECURE=true            # true | false          (default: AppEnv==production)

# Rate limit for POST /oauth/exchange  (default: 0.1 req/s = 1 per 10s)
RATE_LIMIT_OAUTH_EXCHANGE=0.1

# Mobile deep-link in AllowedRedirects (add alongside https:// entries)
OAUTH_GOOGLE_ALLOWED_REDIRECTS=https://app.example.com/dashboard,com.myapp://oauth/callback

# ─── Redis Distributed Cache (optional) ─────────────────────────────────────
#
# When REDIS_DSN is set the application uses Redis for:
#   - Rate limiting  (shared token-bucket counters across all pods)
#   - TOTP replay cache  (distributed SET NX EX for RFC 6238 §5.2 compliance)
#
# When REDIS_DSN is empty (the default) the application falls back to
# per-process in-memory stores — identical to the behaviour before this
# feature was added. No other environment variables need to change.
#
# Accepted DSN schemes:
#   redis://[:<password>@]<host>:<port>[/<db>]         — plain TCP
#   rediss://[:<password>@]<host>:<port>[/<db>]        — TLS
#   unix:///<path>?db=<n>                              — Unix socket
#
# Examples:
#
#   Local development (no auth):
#   REDIS_DSN=redis://localhost:6379/0
#
#   Production (TLS + password):
#   REDIS_DSN=rediss://:your_strong_password@redis.internal.example.com:6380/0
#
#   Redis Sentinel / Cluster: use the go-redis URL format documented at
#   https://pkg.go.dev/github.com/redis/go-redis/v9#ParseURL
#
# Security note: the password embedded in REDIS_DSN is never logged.
# Only the sanitised host:port/db is written to startup logs.

# Required when Redis should be active. Without this variable Redis stays off.
REDIS_DSN=redis://localhost:6379/0

# Maximum number of socket connections in the pool (default: 10).
# Tune proportionally to your application's concurrency level.
REDIS_POOL_SIZE=10

# REDIS_ENABLED lets you explicitly opt out of Redis even when REDIS_DSN is
# set (e.g. in a staging environment that shares a .env with production).
# Default: true when REDIS_DSN is set, false when REDIS_DSN is empty.
# Setting REDIS_ENABLED=true without REDIS_DSN is a configuration error.
#
REDIS_ENABLED=false   