APP_ENV=development
APP_PORT=8080

DB_DSN=root:password@tcp(localhost:3306)/auth_db?parseTime=true&charset=utf8mb4&loc=UTC

# Single key — legacy path, works with no other changes
JWT_SECRET=<output of openssl rand -hex 64>

# Multi-key path — use this once you need rotation
JWT_KEYS=[{"id":"v1","secret":"<key1>","active":true}]

# Mid-rotation — both keys present, v2 signs new tokens, v1 still validates old ones
JWT_KEYS=[{"id":"v1","secret":"<key1>","active":false},{"id":"v2","secret":"<key2>","active":true}]
JWT_ISSUER=go-auth-boilerplate
JWT_AUDIENCE=go-auth-boilerplate-users
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

RATE_LIMIT_RATE=5.0
RATE_LIMIT_BURST=10
RATE_LIMIT_MAX_KEYS=10_000

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_HEADERS="Authorization,Content-Type,X-Request-ID"
CORS_ALLOW_CREDENTIALS=true
CORSMaxAge=43200 # 12 hours

SEC_HSTS_ENABLED=false
SEC_HSTS_MAX_AGE=63_072_000 # 2 years
